# Required: Postgres connection string
HUTCH_DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Optional: shared bearer token required on every MCP and REST call.
# If unset, Core accepts anonymous requests (single-user local mode).
# Generate with: openssl rand -hex 32
HUTCH_API_KEY=

# Optional: the public base URL Hutch advertises in tool responses.
# Defaults to http://localhost:3000. Self-hosters running behind a
# reverse proxy or on a custom domain should set this explicitly.
HUTCH_BASE_URL=http://localhost:3111
